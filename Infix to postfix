#include <iostream>
#include <stack>
using namespace std;

int precedence(char op) {
    if(op == '+' || op == '-') return 1;
    if(op == '*' || op == '/') return 2;
    return 0; // unknown operator, like your professor’s mood
}

string infixToPostfix(string s) {
    stack<char> st;
    string result;

    for(char c : s) {
        if(isalnum(c)) {
            result += c; // operands go straight in, no drama
        }
        else if(c == '(') {
            st.push(c);
        }
        else if(c == ')') {
            while(!st.empty() && st.top() != '(') {
                result += st.top();
                st.pop();
            }
            st.pop(); // remove '('
        }
        else {
            while(!st.empty() && precedence(st.top()) >= precedence(c)) {
                result += st.top();
                st.pop();
            }
            st.push(c);
        }
    }

    while(!st.empty()) {
        result += st.top();
        st.pop();
    }

    return result;
}

int main() {
    string s;
    cin >> s;

    cout << infixToPostfix(s);
}

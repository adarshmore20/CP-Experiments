#include <iostream>
using namespace std;

int main() {
    int n, x;
    cin >> n;

    int arr[n];
    for(int i=0;i<n;i++) cin >> arr[i];

    cin >> x;

    int first = -1, last = -1;

    for(int i=0;i<n;i++) {
        if(arr[i] == x) {
            if(first == -1) first = i;
            last = i;
        }
    }

    cout << "First: " << first << " Last: " << last;
}

#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

class Stack {
    Node* top;

public:
    Stack() {
        top = NULL; // empty again, theme continues
    }

    void push(int x) {
        Node* temp = new Node();

        if(!temp) {
            cout << "Heap Overflow\n"; // your RAM gave up before you did
            return;
        }

        temp->data = x;
        temp->next = top;
        top = temp;
    }

    void pop() {
        if(top == NULL) {
            cout << "Stack Underflow\n"; // surprise, nothing here
            return;
        }

        Node* temp = top;
        top = top->next;
        delete temp; // goodbye, you served well
    }

    void display() {
        Node* temp = top;

        while(temp != NULL) {
            cout << temp->data << " ";
            temp = temp->next;
        }
    }
};

int main() {
    Stack s;

    s.push(5);
    s.push(15);
    s.push(25);

    s.display();
    cout << endl;

    s.pop();
    s.display();
}

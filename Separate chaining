#include <iostream>
#include <vector>
using namespace std;

int main() {
    int size, n;
    cin >> size >> n;

    vector<int> hash[size];

    for(int i=0;i<n;i++) {
        int val;
        cin >> val;
        int index = val % size;
        hash[index].push_back(val);
    }

    for(int i=0;i<size;i++) {
        cout << i << ": ";
        for(int x : hash[i])
            cout << x << " ";
        cout << endl;
    }
}

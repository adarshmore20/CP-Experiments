#include <iostream>
#include <stack>
using namespace std;

bool isBalanced(string s) {
    stack<char> st;

    for(char c : s) {
        if(c == '(' || c == '{' || c == '[') {
            st.push(c); // stacking problems like your life decisions
        }
        else {
            if(st.empty()) return false;

            char top = st.top();
            st.pop();

            if((c == ')' && top != '(') ||
               (c == '}' && top != '{') ||
               (c == ']' && top != '[')) {
                return false; // mismatch, like your expectations vs reality
            }
        }
    }

    return st.empty(); // if still not empty, something is VERY wrong
}

int main() {
    string s;
    cin >> s;

    if(isBalanced(s))
        cout << "Balanced";
    else
        cout << "Not Balanced";
}

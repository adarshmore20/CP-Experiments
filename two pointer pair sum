#include <iostream>
using namespace std;

int main() {
    int n, x;
    cin >> n;

    int arr[n];
    for(int i=0;i<n;i++) cin >> arr[i];

    cin >> x;

    int l = 0, r = n-1;

    while(l < r) {
        int sum = arr[l] + arr[r];

        if(sum == x) {
            cout << "Found";
            return 0;
        }
        else if(sum < x)
            l++;
        else
            r--;
    }

    cout << "Not Found";
}

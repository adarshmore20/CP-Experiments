#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int arr[n];
    for(int i=0;i<n;i++)
        cin >> arr[i];

    int maxAnd = 0;

    for(int i=0;i<n;i++) {
        for(int j=i+1;j<n;j++) {
            maxAnd = max(maxAnd, arr[i] & arr[j]);
        }
    }

    cout << maxAnd;
    return 0;
}
